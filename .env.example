# =============================================================
# Mediva Designs — Environment Variables
# Copy this file to .env.local for local development.
# Set all variables in your deployment platform for production.
# =============================================================

# ----- Database -----------------------------------------------
# PostgreSQL connection string (required for production).
# Get a free managed Postgres from Neon (https://neon.tech),
# Supabase (https://supabase.com), or Railway (https://railway.app).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/medivadesigns?schema=public"

# ----- NextAuth -----------------------------------------------
# A long random secret used to sign and encrypt session tokens.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# The canonical URL of your deployed site (no trailing slash).
NEXTAUTH_URL="https://your-domain.vercel.app"

# ----- Google OAuth (optional) --------------------------------
# Create credentials at https://console.cloud.google.com
# Authorised redirect URI: https://your-domain.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ----- Stripe -------------------------------------------------
# Get your keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ----- Public variables (exposed to the browser) --------------
# Must match NEXTAUTH_URL exactly.
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
